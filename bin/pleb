#!/usr/bin/env bash
# pleb — manage the "Pleb" kilix kiosk desktop session.
#
#   pleb install            add "Pleb" as a choosable LightDM session (needs sudo)
#   pleb uninstall          remove it
#   pleb test [opts]        try it in a throwaway X server (see: pleb test --help)
#   pleb autologin on|off   boot straight into Pleb (kiosk) / back to greeter
#   pleb kiosk on|off       hard kiosk: respawn kilix if it exits / don't
#   pleb update [-y] [--no-restart|--restart]
#                           pull latest kilix, rebuild, optionally restart kiosk
#   pleb status             show install + engine state
#   pleb version            print the Plebian-OS release version
#   pleb doctor             check prerequisites
#   pleb screen-size ...    show/increase/decrease/reset Kilix terminal scale
#   pleb session            exec the session now (for the current $DISPLAY)
#
# Non-destructive: your current desktop session is untouched; "Pleb" is another choice
# at the login screen. Uninstall removes the session integration while keeping
# downloaded checkouts and any packages installed as dependencies.
set -euo pipefail

# Resolve symlinks so `ln -s .../bin/pleb /usr/local/bin/pleb` still finds the
# checkout (pleb install links it onto PATH exactly that way).
_self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
PLEB_ROOT="$(cd "$(dirname "$_self")/.." && pwd)"
# shellcheck source=/dev/null
. "$PLEB_ROOT/lib/common.sh"
. "$PLEB_ROOT/lib/install.sh"
. "$PLEB_ROOT/lib/autologin.sh"
. "$PLEB_ROOT/lib/test.sh"
. "$PLEB_ROOT/lib/kiosk.sh"
. "$PLEB_ROOT/lib/update.sh"

# print the leading comment block (line 2 until the first non-comment line)
usage() { awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "${BASH_SOURCE[0]}"; }

cmd_status() {
    log "Pleb kiosk desktop — status"
    local eng="$KILIX_DEFAULT"
    if [ -x "$eng" ] && "$eng" --which >/dev/null 2>&1; then
        info "engine   : $("$eng" --which 2>/dev/null | tail -1)  [$eng]"
    else
        info "engine   : NOT RUNNABLE at $eng  (run $KILIX_DIR/bootstrap.sh)"
    fi
    if [ -f "$XSESSION_DST" ]; then info "session  : installed ($XSESSION_DST)"
    else info "session  : not installed  (run: pleb install)"; fi
    if [ -x "$SESSION_BIN_DST" ]; then info "launcher : $SESSION_BIN_DST"
    else info "launcher : not installed"; fi
    if [ -L "$KILIX_LINK" ]; then info "kilix cmd: $KILIX_LINK -> $(readlink "$KILIX_LINK")"
    else info "kilix cmd: not linked (run: pleb install)"; fi
    if desktop_enabled; then
        info "desktop  : enabled via ${KILIX_DESKTOP_PROVIDER:-auto}${KILIX_DESKTOP_NAME:+ ($KILIX_DESKTOP_NAME)}"
    else
        info "desktop  : plain kilix shell"
    fi
    if [ -d "$KILIX95_DIR/.git" ] && [ -f "$KILIX95_DIR/main.py" ]; then
        info "kilix 95 : installed at $KILIX95_DIR"
    else
        info "kilix 95 : optional desktop not installed"
    fi
    if [ -f "$AUTOLOGIN_CONF" ]; then
        info "autologin: ON  -> $(grep -sE '^autologin-user=' "$AUTOLOGIN_CONF" | cut -d= -f2)"
    else
        info "autologin: off (greeter shown)"
    fi
    if kiosk_is_on; then info "kiosk    : HARD (respawn kilix on exit)"
    else info "kiosk    : soft (kilix exit ends the session)"; fi
    local dm; dm="$(basename "$(readlink -f /etc/systemd/system/display-manager.service 2>/dev/null)" 2>/dev/null || echo '?')"
    info "greeter  : $(systemctl is-active display-manager 2>/dev/null || echo unknown) ($dm)"
}

cmd_doctor() {
    local ok=1
    log "checking prerequisites"
    if [ -x "$KILIX_DEFAULT" ] && "$KILIX_DEFAULT" --which >/dev/null 2>&1; then
        info "[ok]  kilix engine: $("$KILIX_DEFAULT" --which 2>/dev/null | tail -1)"
    else
        info "[!!]  kilix engine not runnable at $KILIX_DEFAULT — run: $KILIX_DIR/bootstrap.sh"; ok=0
    fi
    for t in Xorg startx xset xsetroot; do
        if command -v "$t" >/dev/null 2>&1; then info "[ok]  $t"; else info "[!!]  missing: $t"; ok=0; fi
    done
    if command -v Xephyr >/dev/null 2>&1; then info "[ok]  Xephyr (nested testing)"
    else info "[--]  Xephyr absent — 'pleb test' will use a spare VT instead"; fi
    if [ -d /usr/share/xsessions ]; then info "[ok]  /usr/share/xsessions exists"
    else info "[--]  /usr/share/xsessions missing (created on install)"; fi
    if systemctl is-active --quiet lightdm 2>/dev/null; then info "[ok]  lightdm is the active greeter"
    else info "[--]  lightdm not active — session choice UI may differ"; fi
    echo
    if [ "$ok" = 1 ]; then log "doctor: ready to install/test."; else warn "doctor: fix the [!!] items first."; fi
    [ "$ok" = 1 ]
}

cmd_screen_size() {
    [ -x "$KILIX_DEFAULT" ] || die "kilix not runnable at $KILIX_DEFAULT"
    "$KILIX_DEFAULT" screen-size "$@"
}

main() {
    local cmd="${1:-help}"; shift || true
    case "$cmd" in
        install)    do_install ;;
        uninstall)  do_uninstall ;;
        test)       case "${1:-}" in
                        -h|--help) grep -E '^#   pleb test' "$PLEB_ROOT/lib/test.sh" | sed 's/^# //' ;;
                        *) run_test "$@" ;;
                    esac ;;
        autologin)  case "${1:-}" in
                        on)  shift; autologin_on "$@" ;;
                        off) autologin_off ;;
                        *)   die "usage: pleb autologin on [user] | off" ;;
                    esac ;;
        kiosk)      case "${1:-}" in
                        on)  kiosk_on ;;
                        off) kiosk_off ;;
                        *)   die "usage: pleb kiosk on | off" ;;
                    esac ;;
        update)     do_update "$@" ;;
        status)     cmd_status ;;
        doctor)     cmd_doctor ;;
        screen-size|font-size)
                    cmd_screen_size "$@" ;;
        session)    exec "$PLEB_BIN_SRC" ;;
        version|--version|-V)
                    echo "pleb $(cat "$PLEB_ROOT/VERSION" 2>/dev/null || echo unknown)" ;;
        help|-h|--help) usage ;;
        *)          err "unknown command: $cmd"; usage; exit 1 ;;
    esac
}
main "$@"
