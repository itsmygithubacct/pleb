#!/usr/bin/env bash
# pleb-session — the "Pleb" desktop: kilix fullscreen as the only X client.
#
# This is the X session entrypoint. It is run by:
#   - LightDM, via /usr/share/xsessions/pleb.desktop  (Exec=/usr/local/bin/pleb-session)
#   - startx / .xinitrc, for testing on a spare VT
#   - `pleb test`, nested inside Xephyr
#
# It is deliberately SELF-CONTAINED (no sourcing of ~/pleb/lib) so it keeps
# working after it is copied to /usr/local/bin, independent of ~/pleb.
#
# A no-window-manager X session: a single fullscreen kilix client. When kilix
# exits, the X session ends (LightDM returns to the greeter), unless respawn
# (hard-kiosk) mode keeps it alive — see PLEB_RESPAWN below.
#
# Environment knobs:
#   KILIX_DIR         kilix engine checkout        (default: $HOME/kilix)
#   KILIX             path to the kilix launcher   (default: $KILIX_DIR/kilix)
#   PLEB_KILIX_ARGS   extra args passed to kilix   (default: --start-as=fullscreen)
#   PLEB_WM           window manager to run first  (default: none; e.g. "openbox")
#   PLEB_NO_FILL      if =1, skip the no-WM screen-fill sizing (default: off)
#   PLEB_BG           root window solid colour     (default: #101010)
#   PLEB_LOG          session log file             (default: ~/.local/share/pleb/session.log)
#   PLEB_RESPAWN      if =1, relaunch kilix if it exits (kiosk mode); default off
#   PLEB_DESKTOP      if truthy, boot straight into `kilix desktop` instead of
#                     a bare shell; default off
#   KILIX_REF         optional exact Kilix commit/tag for update/install flows
#   KILIX_DESKTOP_PROVIDER auto | builtin | external | command | none
#   KILIX_DESKTOP_COMMAND  shell command used when provider=command
#   KILIX_DESKTOP_NAME     label/title for a custom desktop provider
#   KILIX95_AUTO_INSTALL   allow `kilix desktop` to clone external Kilix 95
#   KILIX95_DIR       external Kilix 95 checkout path (default: $HOME/kilix-95)
#   KILIX95_REPO      external Kilix 95 repo URL
#   KILIX95_BRANCH    optional Kilix 95 branch
#   KILIX95_REF       optional exact Kilix 95 commit/tag
#
# Fullscreen note: kitty's --start-as=fullscreen uses _NET_WM_STATE_FULLSCREEN,
# which only works when a window manager is running. This kiosk runs no WM by
# default, so when none is detected we instead size the kitty window to the
# whole screen in pixels (borderless at 0,0 == effectively fullscreen). Set
# PLEB_WM=openbox (or any EWMH WM) to get native fullscreen + F11 instead.
set -u

# Optional persistent env defaults so knobs survive across logins without editing
# this launcher. System first, then user. Values already present in the real
# environment are restored after sourcing, so `PLEB_DESKTOP=0 pleb session` wins
# over `/etc/pleb/session.env`.
_pleb_vars="KILIX_DIR KILIX KILIX_REF PLEB_KILIX_ARGS PLEB_WM PLEB_NO_FILL PLEB_BG PLEB_LOG PLEB_RESPAWN PLEB_DESKTOP KILIX_DESKTOP_PROVIDER KILIX_DESKTOP_COMMAND KILIX_DESKTOP_NAME KILIX95_AUTO_INSTALL KILIX95_DIR KILIX95_REPO KILIX95_BRANCH KILIX95_REF"
declare -A _pleb_had _pleb_saved
for _pleb_v in $_pleb_vars; do
    if [[ ${!_pleb_v+x} ]]; then
        _pleb_had[$_pleb_v]=1
        _pleb_saved[$_pleb_v]=${!_pleb_v}
    else
        _pleb_had[$_pleb_v]=0
    fi
done
for _pleb_cfg in /etc/pleb/session.env "${XDG_CONFIG_HOME:-$HOME/.config}/pleb/session.env"; do
    # shellcheck source=/dev/null
    [ -r "$_pleb_cfg" ] && . "$_pleb_cfg"
done
for _pleb_v in $_pleb_vars; do
    if [[ ${_pleb_had[$_pleb_v]} = 1 ]]; then
        printf -v "$_pleb_v" '%s' "${_pleb_saved[$_pleb_v]}"
    fi
done
unset _pleb_cfg _pleb_v _pleb_vars _pleb_had _pleb_saved

KILIX_DIR="${KILIX_DIR:-$HOME/kilix}"
KILIX="${KILIX:-$KILIX_DIR/kilix}"
KILIX_REF="${KILIX_REF:-}"
PLEB_KILIX_ARGS="${PLEB_KILIX_ARGS:---start-as=fullscreen}"
PLEB_BG="${PLEB_BG:-#101010}"
PLEB_LOG="${PLEB_LOG:-$HOME/.local/share/pleb/session.log}"
PLEB_RESPAWN="${PLEB_RESPAWN:-0}"
PLEB_DESKTOP="${PLEB_DESKTOP:-0}"
KILIX_DESKTOP_PROVIDER="${KILIX_DESKTOP_PROVIDER:-external}"
KILIX_DESKTOP_COMMAND="${KILIX_DESKTOP_COMMAND:-}"
KILIX_DESKTOP_NAME="${KILIX_DESKTOP_NAME:-desktop}"
KILIX95_AUTO_INSTALL="${KILIX95_AUTO_INSTALL:-1}"
KILIX95_DIR="${KILIX95_DIR:-$HOME/kilix-95}"
KILIX95_REPO="${KILIX95_REPO:-https://github.com/itsmygithubacct/kilix-95.git}"
KILIX95_BRANCH="${KILIX95_BRANCH:-}"
KILIX95_REF="${KILIX95_REF:-}"
read -r -a KILIX_ARGV <<< "$PLEB_KILIX_ARGS"

# --- logging -----------------------------------------------------------------
mkdir -p "$(dirname "$PLEB_LOG")" 2>/dev/null || true
# keep the log from growing without bound across relogins
_trim_log() {
    if [ -f "$PLEB_LOG" ] && [ "$(wc -c <"$PLEB_LOG" 2>/dev/null || echo 0)" -gt 1048576 ]; then
        tail -c 262144 "$PLEB_LOG" >"$PLEB_LOG.tmp" 2>/dev/null \
            && cat "$PLEB_LOG.tmp" >"$PLEB_LOG" 2>/dev/null
        rm -f "$PLEB_LOG.tmp"
    fi
}
_trim_log
exec >>"$PLEB_LOG" 2>&1
echo "=== pleb-session start $(date) DISPLAY=${DISPLAY:-?} user=$(id -un) ==="

export XDG_CURRENT_DESKTOP=Pleb
export XDG_SESSION_DESKTOP=pleb

# --- desktop notifications: a D-Bus session bus ------------------------------
# Pleb runs no desktop environment, so notify-send / libnotify and kitty's
# OSC 9/99 notifications need a freedesktop notification daemon (Plebian-OS
# ships xfce4-notifyd) — which is D-Bus-activated and so needs a *session* bus.
# LightDM + systemd (dbus-user-session) normally hand us one; if not (e.g.
# `pleb test` on a spare VT) start a private one that dies with the session.
# Best-effort: a no-op when a bus is already present or dbus-launch is absent.
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && command -v dbus-launch >/dev/null 2>&1; then
    echo "--- no session bus inherited: starting one (dbus-launch) ---"
    eval "$(dbus-launch --sh-syntax --exit-with-session 2>/dev/null)" || true
fi
# and make DISPLAY/XAUTHORITY visible on the bus, so the notification daemon —
# started on demand when the first notification arrives — can reach our X server.
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus-update-activation-environment --systemd DISPLAY XAUTHORITY 2>/dev/null || true
fi

# --- kiosk display setup -----------------------------------------------------
# no screen blanking, no DPMS power-off, solid background.
xset s off        2>/dev/null || true
xset s noblank    2>/dev/null || true
xset -dpms        2>/dev/null || true
xsetroot -solid "$PLEB_BG" 2>/dev/null || true

# --- locate a runnable kilix -------------------------------------------------
if [ ! -x "$KILIX" ]; then
    echo "FATAL: kilix not found/executable at: $KILIX" >&2
    # don't strand the user on a black screen — drop to a terminal if we can
    if command -v xterm >/dev/null 2>&1; then
        exec xterm -geometry 100x30 -e sh -c \
            'printf "%s\n\n" "pleb: kilix missing at: $1"; exec "${SHELL:-/bin/sh}"' sh "$KILIX"
    fi
    exit 1
fi

# --- optional window manager -------------------------------------------------
# If asked for a WM, start it in the background before kilix so kitty's native
# fullscreen (and F11) work. Give it a moment to own the display.
if [ -n "${PLEB_WM:-}" ]; then
    read -r -a PLEB_WM_ARGV <<< "$PLEB_WM"
    if command -v "${PLEB_WM_ARGV[0]}" >/dev/null 2>&1; then
        echo "--- starting WM: $PLEB_WM ---"
        "${PLEB_WM_ARGV[@]}" &
        sleep 0.5
    else
        echo "WARN: PLEB_WM='$PLEB_WM' not found; continuing without it" >&2
    fi
fi

# --- fullscreen strategy -----------------------------------------------------
# A WM is present if the root window advertises _NET_SUPPORTING_WM_CHECK.
_have_wm() { xprop -root _NET_SUPPORTING_WM_CHECK 2>/dev/null | grep -q '0x'; }

# Screen size in "WxH" (xdpyinfo first, xrandr fallback), else empty.
_screen_wh() {
    xdpyinfo 2>/dev/null | awk '/dimensions:/ {print $2; exit}' \
      || xrandr --current 2>/dev/null | awk '/\*/ {print $1; exit}'
}

FILL_ARGS=()
if [ "${PLEB_NO_FILL:-0}" != 1 ] && ! _have_wm; then
    wh="$(_screen_wh)"
    w="${wh%x*}"; h="${wh#*x}"
    if [ -n "$wh" ] && [ "$w" -gt 0 ] 2>/dev/null && [ "$h" -gt 0 ] 2>/dev/null; then
        echo "--- no WM: sizing kitty to ${w}x${h} (screen-fill) ---"
        FILL_ARGS=(-o "initial_window_width=${w}" -o "initial_window_height=${h}"
                   -o remember_window_size=no -o hide_window_decorations=yes
                   -o window_margin_width=0 -o placement_strategy=top-left)
    else
        echo "WARN: could not detect screen size; relying on --start-as only" >&2
    fi
fi

# --- optional: boot straight into the configured kilix desktop ----------------
# The desktop isn't a standalone X client — it renders inside a kilix/kitty
# window via the graphics protocol. So we run the fullscreen kilix window as
# usual but hand it `kilix desktop` as its startup PROGRAM (KILIX_IN_OVERLAY=1
# renders it directly in this one window instead of spawning a tab). It must
# come AFTER the kitty options above (FILL_ARGS), so append it last. Shells the
# desktop later opens (its Terminal icon, panes) still use the normal shell —
# only window 1's program is replaced.
_pleb_desktop_enabled() {
    case "${PLEB_DESKTOP:-0}" in
        1|yes|true|on|desktop|kilix95|kilix-95|command|custom) return 0 ;;
        *) return 1 ;;
    esac
}

DESKTOP_ARGS=()
if _pleb_desktop_enabled; then
    echo "--- PLEB_DESKTOP=$PLEB_DESKTOP: session program is 'kilix desktop' ($KILIX_DESKTOP_PROVIDER) ---"
    DESKTOP_ARGS=(env KILIX_IN_OVERLAY=1
                  "KILIX_REF=$KILIX_REF"
                  "KILIX_DESKTOP_PROVIDER=$KILIX_DESKTOP_PROVIDER"
                  "KILIX_DESKTOP_COMMAND=$KILIX_DESKTOP_COMMAND"
                  "KILIX_DESKTOP_NAME=$KILIX_DESKTOP_NAME"
                  "KILIX95_AUTO_INSTALL=$KILIX95_AUTO_INSTALL"
                  "KILIX95_DIR=$KILIX95_DIR"
                  "KILIX95_REPO=$KILIX95_REPO"
                  "KILIX95_BRANCH=$KILIX95_BRANCH"
                  "KILIX95_REF=$KILIX95_REF"
                  "$KILIX" desktop)
fi

# --- hand off to kilix -------------------------------------------------------
if [ "$PLEB_RESPAWN" = 1 ]; then
    # kiosk: keep a kilix alive for the life of the X session
    crashes=0
    delay=1
    while :; do
        _trim_log
        start=$(date +%s)
        printf -- '--- launching'
        printf ' %q' "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
        printf ' (%s) ---\n' "$(date)"
        "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
        rc=$?
        runtime=$(($(date +%s) - start))
        echo "kilix exited rc=$rc after ${runtime}s"
        if [ "$runtime" -lt 10 ]; then
            crashes=$((crashes + 1))
            [ "$delay" -lt 30 ] && delay=$((delay * 2))
        else
            crashes=0
            delay=1
        fi
        if [ "$crashes" -ge 5 ]; then
            echo "FATAL: kilix crashed too quickly five times; stopping respawn" >&2
            if command -v xterm >/dev/null 2>&1; then
                exec xterm -geometry 100x30 -e sh -c \
                    'printf "%s\n\n" "pleb: kilix is crash-looping; see $1"; exec "${SHELL:-/bin/sh}"' sh "$PLEB_LOG"
            fi
            exit "$rc"
        fi
        echo "--- respawning in ${delay}s ---"
        sleep "$delay"
    done
else
    printf -- '--- exec'
    printf ' %q' "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
    printf ' ---\n'
    exec "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
fi
