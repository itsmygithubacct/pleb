#!/usr/bin/env bash
# pleb-session — the "Pleb" desktop: kilix fullscreen as the only X client.
#
# This is the X session entrypoint. It is run by:
#   - LightDM, via /usr/share/xsessions/pleb.desktop  (Exec=/usr/local/bin/pleb-session)
#   - startx / .xinitrc, for testing on a spare VT
#   - `pleb test`, nested inside Xephyr
#
# It is deliberately SELF-CONTAINED (no sourcing of the Pleb checkout) so it
# keeps working after it is copied to /usr/local/bin.
#
# A no-window-manager X session: a single fullscreen kilix client. When kilix
# exits, the X session ends (LightDM returns to the greeter), unless respawn
# (hard-kiosk) mode keeps it alive — see PLEB_RESPAWN below.
#
# Environment knobs:
#   KILIX_DIR         kilix checkout (default: $HOME/gpu_terminal/kilix)
#   KILIX             path to the kilix launcher   (default: $KILIX_DIR/kilix)
#   PLEB_KILIX_ARGS   extra args passed to kilix   (default: native fullscreen
#                     when a WM is present; no-WM sessions use screen-fill)
#   PLEB_WM           window manager to run first  (default: none; e.g. "openbox")
#   PLEB_NO_FILL      if =1, skip the no-WM screen-fill sizing (default: off)
#   PLEB_BG           root window solid colour     (default: #101010)
#   PLEB_LOG          session log file (default: ~/.local/gpu_terminal/pleb/state/session.log)
#   PLEB_RESPAWN      if =1, relaunch kilix if it exits (kiosk mode); default off
#   PLEB_DESKTOP      if truthy, boot straight into `kilix desktop` instead of
#                     a bare shell; default off
#   KILIX_REF         optional full Kilix commit SHA for update/install flows
#   KILIX_ALLOW_MUTABLE_REF allow a tag/branch KILIX_REF only when explicitly 1
#   KILIX_DESKTOP_PROVIDER auto | builtin | external | command | none
#   KILIX_DESKTOP_COMMAND  shell command used when provider=command
#   KILIX_DESKTOP_NAME     label/title for a custom desktop provider
#   KILIX_DESKTOP_FLAVOR   first-launch desktop flavor (95 or xp)
#   KILIX95_AUTO_INSTALL   allow `kilix desktop` to clone external Kilix 95
#   KILIX95_DIR       external Kilix 95 checkout
#                     (default: $HOME/gpu_terminal/kilix-95)
#   KILIX95_REPO      external Kilix 95 repo URL
#   KILIX95_BRANCH    optional Kilix 95 branch
#   KILIX95_REF       optional full Kilix 95 commit SHA
#   KILIX95_ALLOW_MUTABLE_REF allow a tag/branch KILIX95_REF only when 1
#   KILIX95_ALLOW_UNPINNED_INSTALL allow an automatic clone without a ref
#
# Fullscreen note: kitty's --start-as=fullscreen uses _NET_WM_STATE_FULLSCREEN,
# which only works when a window manager is running. This kiosk runs no WM by
# default, so when none is detected we instead size the kitty window to the
# whole screen in pixels (borderless at 0,0 == effectively fullscreen). Set
# PLEB_WM=openbox (or any EWMH WM) to get native fullscreen + F11 instead.
set -u
[ "$(id -u)" != 0 ] || { echo "pleb-session refuses to run as root" >&2; exit 1; }
umask 077

# Optional persistent env defaults so knobs survive across logins without editing
# this launcher. System first, then user. Values already present in the real
# environment are restored after sourcing, so `PLEB_DESKTOP=0 pleb session` wins
# over `/etc/pleb/session.env`.
PLEB_ENV_SYSTEM="${PLEB_ENV_SYSTEM:-/etc/pleb/session.env}"
if [[ ! ${PLEB_ENV_USER+x} ]]; then
    if [[ ${PLEB_CONFIG_HOME+x} ]]; then
        PLEB_ENV_USER="$PLEB_CONFIG_HOME/session.env"
    elif [[ ${PLEB_STORAGE_HOME+x} ]]; then
        PLEB_ENV_USER="$PLEB_STORAGE_HOME/config/session.env"
    elif [[ ${GPU_TERMINAL_HOME+x} ]]; then
        PLEB_ENV_USER="$GPU_TERMINAL_HOME/pleb/config/session.env"
    else
        PLEB_ENV_USER="$HOME/.local/gpu_terminal/pleb/config/session.env"
    fi
fi

_pleb_vars="GPU_TERMINAL_SOURCE_HOME GPU_TERMINAL_HOME PLEB_STORAGE_HOME PLEB_CONFIG_HOME PLEB_STATE_HOME PLEB_CACHE_HOME PLEB_SESSION_HOME PLEB_DATA_HOME KILIX_STORAGE_HOME KILIX_CONFIG_HOME KILIX_STATE_DIRECTORY KILIX_CACHE_HOME KILIX_SESSION_HOME KILIX_DATA_HOME KILIX_BUILD_DIRECTORY KILIX_PREBUILT_HOME KILIX95_STORAGE_HOME KILIX95_CONFIG_HOME KILIX95_STATE_HOME KILIX95_CACHE_HOME KILIX95_SESSION_HOME KILIX95_DATA_HOME KILIX_DESKTOP_DIR KILIX_DIR KILIX KILIX_REF KILIX_ALLOW_MUTABLE_REF PLEB_KILIX_ARGS PLEB_WM PLEB_NO_FILL PLEB_BG PLEB_LOG PLEB_RESPAWN PLEB_DESKTOP KILIX_DESKTOP_PROVIDER KILIX_DESKTOP_COMMAND KILIX_DESKTOP_NAME KILIX_DESKTOP_FLAVOR KILIX95_AUTO_INSTALL KILIX95_DIR KILIX95_REPO KILIX95_BRANCH KILIX95_REF KILIX95_ALLOW_MUTABLE_REF KILIX95_ALLOW_UNPINNED_INSTALL"
declare -A _pleb_had _pleb_saved
for _pleb_v in $_pleb_vars; do
    if [[ ${!_pleb_v+x} ]]; then
        _pleb_had[$_pleb_v]=1
        _pleb_saved[$_pleb_v]=${!_pleb_v}
    else
        _pleb_had[$_pleb_v]=0
    fi
done
for _pleb_cfg in "$PLEB_ENV_SYSTEM" "$PLEB_ENV_USER"; do
    # shellcheck source=/dev/null
    [ -r "$_pleb_cfg" ] && . "$_pleb_cfg"
done
for _pleb_v in $_pleb_vars; do
    if [[ ${_pleb_had[$_pleb_v]} = 1 ]]; then
        printf -v "$_pleb_v" '%s' "${_pleb_saved[$_pleb_v]}"
    fi
done
unset _pleb_cfg _pleb_v _pleb_vars _pleb_had _pleb_saved

GPU_TERMINAL_SOURCE_HOME="${GPU_TERMINAL_SOURCE_HOME:-$HOME/gpu_terminal}"
GPU_TERMINAL_HOME="${GPU_TERMINAL_HOME:-$HOME/.local/gpu_terminal}"
PLEB_STORAGE_HOME="${PLEB_STORAGE_HOME:-$GPU_TERMINAL_HOME/pleb}"
PLEB_CONFIG_HOME="${PLEB_CONFIG_HOME:-$PLEB_STORAGE_HOME/config}"
PLEB_STATE_HOME="${PLEB_STATE_HOME:-$PLEB_STORAGE_HOME/state}"
PLEB_CACHE_HOME="${PLEB_CACHE_HOME:-$PLEB_STORAGE_HOME/cache}"
PLEB_SESSION_HOME="${PLEB_SESSION_HOME:-$PLEB_STORAGE_HOME/session}"
PLEB_DATA_HOME="${PLEB_DATA_HOME:-$PLEB_STORAGE_HOME/data}"
KILIX_STORAGE_HOME="${KILIX_STORAGE_HOME:-$GPU_TERMINAL_HOME/kilix}"
KILIX_CONFIG_HOME="${KILIX_CONFIG_HOME:-$KILIX_STORAGE_HOME/config}"
KILIX_STATE_DIRECTORY="${KILIX_STATE_DIRECTORY:-$KILIX_STORAGE_HOME/state}"
KILIX_CACHE_HOME="${KILIX_CACHE_HOME:-$KILIX_STORAGE_HOME/cache}"
KILIX_SESSION_HOME="${KILIX_SESSION_HOME:-$KILIX_STORAGE_HOME/session}"
KILIX_DATA_HOME="${KILIX_DATA_HOME:-$KILIX_STORAGE_HOME/data}"
KILIX_BUILD_DIRECTORY="${KILIX_BUILD_DIRECTORY:-$KILIX_STORAGE_HOME/build}"
KILIX_PREBUILT_HOME="${KILIX_PREBUILT_HOME:-$KILIX_STORAGE_HOME/prebuilt/kitty.app}"
KILIX95_STORAGE_HOME="${KILIX95_STORAGE_HOME:-$GPU_TERMINAL_HOME/kilix-95}"
KILIX95_CONFIG_HOME="${KILIX95_CONFIG_HOME:-$KILIX95_STORAGE_HOME/config}"
KILIX95_STATE_HOME="${KILIX95_STATE_HOME:-$KILIX95_STORAGE_HOME/state}"
KILIX95_CACHE_HOME="${KILIX95_CACHE_HOME:-$KILIX95_STORAGE_HOME/cache}"
KILIX95_SESSION_HOME="${KILIX95_SESSION_HOME:-$KILIX95_STORAGE_HOME/session}"
KILIX95_DATA_HOME="${KILIX95_DATA_HOME:-$KILIX95_STORAGE_HOME/data}"
KILIX_DESKTOP_DIR="${KILIX_DESKTOP_DIR:-$PLEB_DATA_HOME/desktop}"
export GPU_TERMINAL_SOURCE_HOME GPU_TERMINAL_HOME
export PLEB_STORAGE_HOME PLEB_CONFIG_HOME PLEB_STATE_HOME PLEB_CACHE_HOME
export PLEB_SESSION_HOME PLEB_DATA_HOME KILIX_STORAGE_HOME KILIX_CONFIG_HOME
export KILIX_STATE_DIRECTORY KILIX_CACHE_HOME KILIX_SESSION_HOME KILIX_DATA_HOME
export KILIX_BUILD_DIRECTORY KILIX_PREBUILT_HOME KILIX95_STORAGE_HOME KILIX95_CONFIG_HOME
export KILIX95_STATE_HOME KILIX95_CACHE_HOME KILIX95_SESSION_HOME KILIX95_DATA_HOME
export KILIX_DESKTOP_DIR
export PLEB_ENV_SYSTEM PLEB_ENV_USER

# Keep the complete Pleb storage layout private before the first log, cache, or
# desktop-data write. This mirrors lib/storage.sh because the installed session
# launcher is intentionally self-contained and cannot depend on its checkout.
_pleb_storage_fail() {
    echo "pleb-session: $*" >&2
    exit 1
}

_pleb_storage_normalized() {
    local path="$1"
    case "$path" in
        /*) ;;
        *) _pleb_storage_fail "Pleb writable-data path must be absolute: $path" ;;
    esac
    [[ "$path" != *$'\n'* && "$path" != *$'\r'* ]] \
        || _pleb_storage_fail "Pleb writable-data path contains a line break"
    realpath -m -- "$path" 2>/dev/null \
        || _pleb_storage_fail "could not normalize Pleb writable-data path: $path"
}

_pleb_storage_no_links() {
    local path="$1" current="" component
    local -a components
    IFS=/ read -r -a components <<<"${path#/}"
    for component in "${components[@]}"; do
        [ -n "$component" ] || continue
        current="$current/$component"
        [ ! -L "$current" ] \
            || _pleb_storage_fail "refusing Pleb writable-data path with a symlink component: $current"
        if [ -e "$current" ]; then
            [ -d "$current" ] \
                || _pleb_storage_fail "Pleb writable-data parent is not a directory: $current"
        fi
    done
}

_pleb_storage_safe_parents() {
    local path="$1" parent current="" component mode owner user_id
    local -a components
    user_id="$(id -u)"
    parent="$(dirname "$path")"
    IFS=/ read -r -a components <<<"${parent#/}"
    for component in "${components[@]}"; do
        [ -n "$component" ] || continue
        current="$current/$component"
        [ ! -L "$current" ] \
            || _pleb_storage_fail "refusing Pleb writable-data path with a symlink component: $current"
        if [ -e "$current" ]; then
            [ -d "$current" ] \
                || _pleb_storage_fail "Pleb writable-data parent is not a directory: $current"
            owner="$(stat -c '%u' "$current" 2>/dev/null)" \
                || _pleb_storage_fail "could not inspect Pleb writable-data parent owner: $current"
            case "$owner" in
                0|"$user_id") ;;
                *) _pleb_storage_fail "Pleb writable-data parent has an unsafe owner: $current" ;;
            esac
            mode="$(stat -c '%a' "$current" 2>/dev/null)" \
                || _pleb_storage_fail "could not inspect Pleb writable-data parent: $current"
            if [ "$current" != "$PLEB_STORAGE_HOME" ] \
                && (( (8#$mode & 8#22) != 0 )); then
                case "$current" in
                    "$PLEB_STORAGE_HOME"/*)
                        _pleb_storage_fail "refusing Pleb writable data below a group/world-writable parent: $current" ;;
                    *)
                        (( (8#$mode & 8#1000) != 0 )) \
                            || _pleb_storage_fail "refusing Pleb writable data below a group/world-writable parent: $current" ;;
                esac
            fi
        fi
    done
}

_pleb_storage_input() {
    local path="${1%/}"
    [ -n "$path" ] || path=/
    printf '%s\n' "$path"
}

_pleb_storage_private_dir() {
    local path="$1" owner
    case "$path" in
        "$PLEB_STORAGE_HOME"|"$PLEB_STORAGE_HOME"/*) ;;
        *) _pleb_storage_fail "Pleb writable-data directory escapes PLEB_STORAGE_HOME: $path" ;;
    esac
    _pleb_storage_safe_parents "$path"
    _pleb_storage_no_links "$path"
    ( umask 077; mkdir -p -- "$path" ) \
        || _pleb_storage_fail "could not create Pleb writable-data directory: $path"
    _pleb_storage_safe_parents "$path"
    _pleb_storage_no_links "$path"
    [ -d "$path" ] && [ ! -L "$path" ] \
        || _pleb_storage_fail "refusing unsafe Pleb writable-data directory: $path"
    owner="$(stat -c '%u' "$path" 2>/dev/null)" \
        || _pleb_storage_fail "could not inspect Pleb writable-data directory: $path"
    [ "$owner" = "$(id -u)" ] \
        || _pleb_storage_fail "Pleb writable-data directory is not owned by the current user: $path"
    chmod 0700 -- "$path" \
        || _pleb_storage_fail "could not make Pleb writable-data directory private: $path"
}

_pleb_ensure_private_storage() {
    local data_root storage source input normalized var path owner current component
    local -a categories components
    [ "$(id -u)" != 0 ] \
        || _pleb_storage_fail "Pleb private storage must be managed as the desktop user; run Pleb without sudo"
    data_root="$(_pleb_storage_normalized "$GPU_TERMINAL_HOME")"
    storage="$(_pleb_storage_normalized "$PLEB_STORAGE_HOME")"
    source="$(_pleb_storage_normalized "$GPU_TERMINAL_SOURCE_HOME")"
    _pleb_storage_no_links "$GPU_TERMINAL_HOME"
    _pleb_storage_no_links "$PLEB_STORAGE_HOME"
    input="$(_pleb_storage_input "$GPU_TERMINAL_HOME")"
    [ "$input" = "$data_root" ] \
        || _pleb_storage_fail "GPU_TERMINAL_HOME must be a normalized absolute path: $GPU_TERMINAL_HOME"
    input="$(_pleb_storage_input "$PLEB_STORAGE_HOME")"
    [ "$input" = "$storage" ] \
        || _pleb_storage_fail "PLEB_STORAGE_HOME must be a normalized absolute path: $PLEB_STORAGE_HOME"
    case "$data_root" in
        /|/bin|/boot|/dev|/etc|/home|/lib|/lib64|/media|/mnt|/opt|/proc|/root|/run|/sbin|/srv|/sys|/tmp|/usr|/var)
            _pleb_storage_fail "GPU_TERMINAL_HOME is too broad for writable application data: $data_root" ;;
    esac
    case "$data_root" in
        "$source"|"$source"/*)
            _pleb_storage_fail "GPU_TERMINAL_HOME must not place writable data in the source tree: $source" ;;
    esac
    case "$storage" in
        "$data_root"/*) ;;
        *) _pleb_storage_fail "PLEB_STORAGE_HOME must be a strict descendant of GPU_TERMINAL_HOME ($data_root): $storage" ;;
    esac
    case "$storage" in
        /|"${HOME%/}") _pleb_storage_fail "PLEB_STORAGE_HOME is too broad for Pleb writable data: $storage" ;;
    esac

    categories=(
        PLEB_CONFIG_HOME PLEB_STATE_HOME PLEB_CACHE_HOME
        PLEB_SESSION_HOME PLEB_DATA_HOME
    )
    for var in "${categories[@]}"; do
        path="${!var}"
        normalized="$(_pleb_storage_normalized "$path")"
        _pleb_storage_no_links "$path"
        input="$(_pleb_storage_input "$path")"
        [ "$input" = "$normalized" ] \
            || _pleb_storage_fail "$var must be a normalized absolute path: $path"
        case "$normalized" in
            "$storage"/*) ;;
            *) _pleb_storage_fail "$var must be a strict descendant of PLEB_STORAGE_HOME ($storage): $normalized" ;;
        esac
        printf -v "$var" '%s' "$normalized"
    done

    _pleb_storage_safe_parents "$storage"
    for path in "$PLEB_CONFIG_HOME" "$PLEB_STATE_HOME" "$PLEB_CACHE_HOME" \
        "$PLEB_SESSION_HOME" "$PLEB_DATA_HOME"; do
        _pleb_storage_safe_parents "$path"
    done
    for path in "$storage" \
        "$PLEB_CONFIG_HOME" "$PLEB_STATE_HOME" "$PLEB_CACHE_HOME" \
        "$PLEB_SESSION_HOME" "$PLEB_DATA_HOME"; do
        _pleb_storage_no_links "$path"
        if [ -e "$path" ] || [ -L "$path" ]; then
            [ -d "$path" ] && [ ! -L "$path" ] \
                || _pleb_storage_fail "refusing unsafe Pleb writable-data directory: $path"
            owner="$(stat -c '%u' "$path" 2>/dev/null)" \
                || _pleb_storage_fail "could not inspect Pleb writable-data directory: $path"
            [ "$owner" = "$(id -u)" ] \
                || _pleb_storage_fail "Pleb writable-data directory is not owned by the current user: $path"
        fi
    done
    for path in "$PLEB_CONFIG_HOME" "$PLEB_STATE_HOME" "$PLEB_CACHE_HOME" \
        "$PLEB_SESSION_HOME" "$PLEB_DATA_HOME"; do
        current="$storage"
        IFS=/ read -r -a components <<<"${path#"$storage"/}"
        for component in "${components[@]}"; do
            [ -n "$component" ] || continue
            current="$current/$component"
            [ -e "$current" ] || continue
            owner="$(stat -c '%u' "$current" 2>/dev/null)" \
                || _pleb_storage_fail "could not inspect Pleb writable-data directory: $current"
            [ "$owner" = "$(id -u)" ] \
                || _pleb_storage_fail "Pleb writable-data directory is not owned by the current user: $current"
        done
    done

    GPU_TERMINAL_HOME="$data_root"
    PLEB_STORAGE_HOME="$storage"
    _pleb_storage_private_dir "$PLEB_STORAGE_HOME"
    _pleb_storage_private_dir "$PLEB_CONFIG_HOME"
    _pleb_storage_private_dir "$PLEB_STATE_HOME"
    _pleb_storage_private_dir "$PLEB_CACHE_HOME"
    _pleb_storage_private_dir "$PLEB_SESSION_HOME"
    _pleb_storage_private_dir "$PLEB_DATA_HOME"
}

_pleb_ensure_private_storage
unset -f _pleb_storage_fail _pleb_storage_normalized _pleb_storage_no_links \
    _pleb_storage_safe_parents _pleb_storage_input _pleb_storage_private_dir \
    _pleb_ensure_private_storage

KILIX_DIR="${KILIX_DIR:-$GPU_TERMINAL_SOURCE_HOME/kilix}"
KILIX="${KILIX:-$KILIX_DIR/kilix}"
KILIX_REF="${KILIX_REF:-}"
KILIX_ALLOW_MUTABLE_REF="${KILIX_ALLOW_MUTABLE_REF:-0}"
if [[ ${PLEB_KILIX_ARGS+x} ]]; then
    _PLEB_KILIX_ARGS_DEFAULT=0
else
    PLEB_KILIX_ARGS=""
    _PLEB_KILIX_ARGS_DEFAULT=1
fi
PLEB_BG="${PLEB_BG:-#101010}"
PLEB_LOG="${PLEB_LOG:-$PLEB_STATE_HOME/session.log}"
PLEB_RESPAWN="${PLEB_RESPAWN:-0}"
case "$PLEB_RESPAWN" in
    1|yes|true|on) PLEB_RESPAWN=1 ;;
    *) PLEB_RESPAWN=0 ;;
esac
PLEB_DESKTOP="${PLEB_DESKTOP:-0}"
KILIX_DESKTOP_PROVIDER="${KILIX_DESKTOP_PROVIDER:-auto}"
KILIX_DESKTOP_COMMAND="${KILIX_DESKTOP_COMMAND:-}"
KILIX_DESKTOP_NAME="${KILIX_DESKTOP_NAME:-desktop}"
KILIX_DESKTOP_FLAVOR="${KILIX_DESKTOP_FLAVOR:-}"
KILIX95_AUTO_INSTALL="${KILIX95_AUTO_INSTALL:-1}"
KILIX95_DIR="${KILIX95_DIR:-$GPU_TERMINAL_SOURCE_HOME/kilix-95}"
KILIX95_REPO="${KILIX95_REPO:-https://github.com/itsmygithubacct/kilix-95.git}"
KILIX95_BRANCH="${KILIX95_BRANCH:-}"
KILIX95_REF="${KILIX95_REF:-}"
KILIX95_ALLOW_MUTABLE_REF="${KILIX95_ALLOW_MUTABLE_REF:-0}"
KILIX95_ALLOW_UNPINNED_INSTALL="${KILIX95_ALLOW_UNPINNED_INSTALL:-0}"
export KILIX_DIR KILIX KILIX95_DIR

# --- logging -----------------------------------------------------------------
# The state directory and log contain recent-path and session metadata. Keep
# them private, reject link tricks, and rotate once per login before opening the
# descriptor. The containing directory is private, so the validation/open pair
# cannot be raced by another local account.
case "$PLEB_LOG" in
    /*) ;;
    *) echo "pleb-session: session log path must be absolute: $PLEB_LOG" >&2; exit 1 ;;
esac
_pleb_log_dir="$(dirname "$PLEB_LOG")"
mkdir -p -- "$_pleb_log_dir" \
    || { echo "pleb-session: cannot create log directory: $_pleb_log_dir" >&2; exit 1; }
if [ ! -d "$_pleb_log_dir" ] || [ -L "$_pleb_log_dir" ] \
    || [ "$(stat -c '%u' "$_pleb_log_dir" 2>/dev/null)" != "$(id -u)" ]; then
    echo "pleb-session: refusing unsafe log directory: $_pleb_log_dir" >&2
    exit 1
fi
chmod 0700 -- "$_pleb_log_dir" \
    || { echo "pleb-session: cannot make log directory private: $_pleb_log_dir" >&2; exit 1; }

if [ -e "$PLEB_LOG" ] || [ -L "$PLEB_LOG" ]; then
    if [ ! -f "$PLEB_LOG" ] || [ -L "$PLEB_LOG" ] \
        || [ "$(stat -c '%u' "$PLEB_LOG" 2>/dev/null)" != "$(id -u)" ] \
        || [ "$(stat -c '%h' "$PLEB_LOG" 2>/dev/null)" != 1 ]; then
        echo "pleb-session: refusing unsafe session log: $PLEB_LOG" >&2
        exit 1
    fi
    chmod 0600 -- "$PLEB_LOG" \
        || { echo "pleb-session: cannot make log private: $PLEB_LOG" >&2; exit 1; }
    if [ "$(wc -c <"$PLEB_LOG" 2>/dev/null || echo 0)" -gt 1048576 ]; then
        rm -f -- "$PLEB_LOG.1" \
            || { echo "pleb-session: cannot replace rotated log: $PLEB_LOG.1" >&2; exit 1; }
        mv -- "$PLEB_LOG" "$PLEB_LOG.1" \
            || { echo "pleb-session: cannot rotate session log: $PLEB_LOG" >&2; exit 1; }
    fi
fi
: >>"$PLEB_LOG" \
    || { echo "pleb-session: cannot open session log: $PLEB_LOG" >&2; exit 1; }
chmod 0600 -- "$PLEB_LOG" \
    || { echo "pleb-session: cannot make log private: $PLEB_LOG" >&2; exit 1; }
unset _pleb_log_dir
exec >>"$PLEB_LOG" 2>&1
echo "=== pleb-session start $(date) DISPLAY=${DISPLAY:-?} user=$(id -un) ==="

export XDG_CURRENT_DESKTOP=Pleb
export XDG_SESSION_DESKTOP=pleb

# --- desktop notifications: a D-Bus session bus ------------------------------
# Pleb runs no desktop environment, so notify-send / libnotify and kitty's
# OSC 9/99 notifications need a freedesktop notification daemon (Plebian-OS
# ships xfce4-notifyd) — which is D-Bus-activated and so needs a *session* bus.
# LightDM + systemd (dbus-user-session) normally hand us one; if not (e.g.
# `pleb test` on a spare VT) start a private one that dies with the session.
# Best-effort: a no-op when a bus is already present or dbus-launch is absent.
if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && command -v dbus-launch >/dev/null 2>&1; then
    echo "--- no session bus inherited: starting one (dbus-launch) ---"
    eval "$(dbus-launch --sh-syntax --exit-with-session 2>/dev/null)" || true
fi
# and make DISPLAY/XAUTHORITY visible on the bus, so the notification daemon —
# started on demand when the first notification arrives — can reach our X server.
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus-update-activation-environment --systemd DISPLAY XAUTHORITY 2>/dev/null || true
fi

# --- kiosk display setup -----------------------------------------------------
# no screen blanking, no DPMS power-off, solid background.
xset s off        2>/dev/null || true
xset s noblank    2>/dev/null || true
xset -dpms        2>/dev/null || true
xset b off        2>/dev/null || xset -b 2>/dev/null || true
xsetroot -solid "$PLEB_BG" 2>/dev/null || true

# --- locate a runnable kilix -------------------------------------------------
if [ ! -x "$KILIX" ]; then
    echo "FATAL: kilix not found/executable at: $KILIX" >&2
    # don't strand the user on a black screen — drop to a terminal if we can
    if command -v xterm >/dev/null 2>&1; then
        exec xterm -geometry 100x30 -e sh -c \
            'printf "%s\n\n" "pleb: kilix missing at: $1"; exec "${SHELL:-/bin/sh}"' sh "$KILIX"
    fi
    exit 1
fi

# --- optional window manager -------------------------------------------------
# If asked for a WM, start it in the background before kilix so kitty's native
# fullscreen (and F11) work. Give it a moment to own the display.
if [ -n "${PLEB_WM:-}" ]; then
    read -r -a PLEB_WM_ARGV <<< "$PLEB_WM"
    if command -v "${PLEB_WM_ARGV[0]}" >/dev/null 2>&1; then
        echo "--- starting WM: $PLEB_WM ---"
        "${PLEB_WM_ARGV[@]}" &
        sleep 0.5
    else
        echo "WARN: PLEB_WM='$PLEB_WM' not found; continuing without it" >&2
    fi
fi

# --- fullscreen strategy -----------------------------------------------------
# A WM is present if the root window advertises _NET_SUPPORTING_WM_CHECK.
_have_wm() { xprop -root _NET_SUPPORTING_WM_CHECK 2>/dev/null | grep -q '0x'; }

# Screen size in "WxH" (xdpyinfo first, xrandr fallback), else empty.
_screen_wh() {
    xdpyinfo 2>/dev/null | awk '/dimensions:/ {print $2; exit}' \
      || xrandr --current 2>/dev/null | awk '/\*/ {print $1; exit}'
}

FILL_ARGS=()
HAVE_WM=0
_have_wm && HAVE_WM=1
if [ "${PLEB_NO_FILL:-0}" != 1 ] && [ "$HAVE_WM" != 1 ]; then
    wh="$(_screen_wh)"
    w="${wh%x*}"; h="${wh#*x}"
    if [ -n "$wh" ] && [ "$w" -gt 0 ] 2>/dev/null && [ "$h" -gt 0 ] 2>/dev/null; then
        echo "--- no WM: sizing kitty to ${w}x${h} (screen-fill) ---"
        FILL_ARGS=(-o "initial_window_width=${w}" -o "initial_window_height=${h}"
                   -o remember_window_size=no -o hide_window_decorations=yes
                   -o window_margin_width=0 -o placement_strategy=top-left)
    else
        echo "WARN: could not detect screen size; relying on --start-as only" >&2
    fi
fi

KILIX_ARGV=()
if [ "$_PLEB_KILIX_ARGS_DEFAULT" = 1 ]; then
    [ "$HAVE_WM" = 1 ] && KILIX_ARGV=(--start-as=fullscreen)
else
    read -r -a KILIX_ARGV <<< "$PLEB_KILIX_ARGS"
fi

# --- optional: boot straight into the configured kilix desktop ----------------
# The desktop isn't a standalone X client — it renders inside a kilix/kitty
# window via the graphics protocol. So we run the fullscreen kilix window as
# usual but hand it `kilix desktop` as its startup PROGRAM (KILIX_IN_OVERLAY=1
# renders it directly in this one window instead of spawning a tab). It must
# come AFTER the kitty options above (FILL_ARGS), so append it last. Shells the
# desktop later opens (its Terminal icon, panes) still use the normal shell —
# only window 1's program is replaced.
_pleb_desktop_enabled() {
    case "${KILIX_DESKTOP_PROVIDER:-auto}" in
        none|off|disabled) return 1 ;;
    esac
    case "${PLEB_DESKTOP:-0}" in
        1|yes|true|on|desktop|kilix95|kilix-95|command|custom) return 0 ;;
        *) return 1 ;;
    esac
}

DESKTOP_ARGS=()
if _pleb_desktop_enabled; then
    echo "--- PLEB_DESKTOP=$PLEB_DESKTOP: session program is 'kilix desktop' ($KILIX_DESKTOP_PROVIDER) ---"
    DESKTOP_ARGS=(env KILIX_IN_OVERLAY=1
                  "GPU_TERMINAL_SOURCE_HOME=$GPU_TERMINAL_SOURCE_HOME"
                  "GPU_TERMINAL_HOME=$GPU_TERMINAL_HOME"
                  "PLEB_STORAGE_HOME=$PLEB_STORAGE_HOME"
                  "PLEB_CONFIG_HOME=$PLEB_CONFIG_HOME"
                  "PLEB_STATE_HOME=$PLEB_STATE_HOME"
                  "PLEB_CACHE_HOME=$PLEB_CACHE_HOME"
                  "PLEB_SESSION_HOME=$PLEB_SESSION_HOME"
                  "PLEB_DATA_HOME=$PLEB_DATA_HOME"
                  "KILIX_STORAGE_HOME=$KILIX_STORAGE_HOME"
                  "KILIX_CONFIG_HOME=$KILIX_CONFIG_HOME"
                  "KILIX_STATE_DIRECTORY=$KILIX_STATE_DIRECTORY"
                  "KILIX_CACHE_HOME=$KILIX_CACHE_HOME"
                  "KILIX_SESSION_HOME=$KILIX_SESSION_HOME"
                  "KILIX_DATA_HOME=$KILIX_DATA_HOME"
                  "KILIX_BUILD_DIRECTORY=$KILIX_BUILD_DIRECTORY"
                  "KILIX_PREBUILT_HOME=$KILIX_PREBUILT_HOME"
                  "KILIX95_STORAGE_HOME=$KILIX95_STORAGE_HOME"
                  "KILIX95_CONFIG_HOME=$KILIX95_CONFIG_HOME"
                  "KILIX95_STATE_HOME=$KILIX95_STATE_HOME"
                  "KILIX95_CACHE_HOME=$KILIX95_CACHE_HOME"
                  "KILIX95_SESSION_HOME=$KILIX95_SESSION_HOME"
                  "KILIX95_DATA_HOME=$KILIX95_DATA_HOME"
                  "KILIX_DESKTOP_DIR=$KILIX_DESKTOP_DIR"
                  "KILIX_REF=$KILIX_REF"
                  "KILIX_ALLOW_MUTABLE_REF=$KILIX_ALLOW_MUTABLE_REF"
                  "KILIX_DESKTOP_PROVIDER=$KILIX_DESKTOP_PROVIDER"
                  "KILIX_DESKTOP_COMMAND=$KILIX_DESKTOP_COMMAND"
                  "KILIX_DESKTOP_NAME=$KILIX_DESKTOP_NAME"
                  "KILIX_DESKTOP_FLAVOR=$KILIX_DESKTOP_FLAVOR"
                  "KILIX95_AUTO_INSTALL=$KILIX95_AUTO_INSTALL"
                  "KILIX95_DIR=$KILIX95_DIR"
                  "KILIX95_REPO=$KILIX95_REPO"
                  "KILIX95_BRANCH=$KILIX95_BRANCH"
                  "KILIX95_REF=$KILIX95_REF"
                  "KILIX95_ALLOW_MUTABLE_REF=$KILIX95_ALLOW_MUTABLE_REF"
                  "KILIX95_ALLOW_UNPINNED_INSTALL=$KILIX95_ALLOW_UNPINNED_INSTALL"
                  "$KILIX" desktop)
fi

# --- hand off to kilix -------------------------------------------------------
if [ "$PLEB_RESPAWN" = 1 ]; then
    # kiosk: keep a kilix alive for the life of the X session
    crashes=0
    delay=1
    while :; do
        start=$(date +%s)
        printf -- '--- launching'
        printf ' %q' "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
        printf ' (%s) ---\n' "$(date)"
        "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
        rc=$?
        runtime=$(($(date +%s) - start))
        echo "kilix exited rc=$rc after ${runtime}s"
        if [ "$runtime" -lt 10 ]; then
            crashes=$((crashes + 1))
            [ "$delay" -lt 30 ] && delay=$((delay * 2))
        else
            crashes=0
            delay=1
        fi
        if [ "$crashes" -ge 5 ]; then
            echo "FATAL: kilix crashed too quickly five times; stopping respawn" >&2
            if command -v xterm >/dev/null 2>&1; then
                exec xterm -geometry 100x30 -e sh -c \
                    'printf "%s\n\n" "pleb: kilix is crash-looping; see $1"; exec "${SHELL:-/bin/sh}"' sh "$PLEB_LOG"
            fi
            exit "$rc"
        fi
        echo "--- respawning in ${delay}s ---"
        sleep "$delay"
    done
else
    printf -- '--- exec'
    printf ' %q' "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
    printf ' ---\n'
    exec "$KILIX" "${KILIX_ARGV[@]}" "${FILL_ARGS[@]}" "${DESKTOP_ARGS[@]}"
fi
